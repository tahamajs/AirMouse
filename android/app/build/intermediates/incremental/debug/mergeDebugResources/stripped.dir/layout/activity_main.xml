<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- IP address input (simple EditText, no Material dependency) -->
        <EditText
            android:id="@+id/ip_edit_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/ip_hint"
            android:inputType="phone"
            android:imeOptions="actionDone"
            android:autofillHints="ipAddress"
            android:padding="12dp"
            android:background="@android:drawable/editbox_background_normal"
            android:textAppearance="?android:attr/textAppearanceMedium" />

        <!-- Sensor status -->
        <TextView
            android:id="@+id/sensor_status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/checking_sensors"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <!-- Calibrate button -->
        <Button
            android:id="@+id/calibrate_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/calibrate"
            android:layout_marginTop="16dp" />

        <!-- Start button -->
        <Button
            android:id="@+id/start_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/start"
            android:layout_marginTop="8dp" />

        <!-- Status text -->
        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/not_connected"
            android:textAlignment="center"
            android:padding="8dp"
            android:textAppearance="?android:attr/textAppearanceMedium" />

        <!-- Sensitivity slider -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/cursor_speed"
            android:layout_marginTop="16dp"
            android:textAppearance="?android:attr/textAppearanceMedium" />

        <SeekBar
            android:id="@+id/sensitivity_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="25" />

        <TextView
            android:id="@+id/sensitivity_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/speed_default"
            android:gravity="center"
            android:textAppearance="?android:attr/textAppearanceMedium" />

        <!-- Settings button -->
        <Button
            android:id="@+id/settings_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings"
            android:layout_marginTop="16dp" />

        <!-- Debug toggle button -->
        <Button
            android:id="@+id/debug_toggle_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/show_debug" />

        <!-- Orientation indicator -->
        <View
            android:id="@+id/orientation_view"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:background="@drawable/green_square" />

    </LinearLayout>
</ScrollView>