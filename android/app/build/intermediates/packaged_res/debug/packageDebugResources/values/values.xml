    <string name="about_content">
        <![CDATA[
        <b>Air Mouse Pro</b><br/>
        Version %s<br/><br/>
        Turn your Android phone into a wireless air mouse using motion sensors, gesture recognition, and guided setup screens that are built for a complete end-to-end experience.<br/><br/>
        <b>Developed by:</b> Arian Firoozi, Arsalan Talaee<br/>
        <b>Instructors:</b> Dr. Mohsen Shokri, Dr. Mehdi Kargahi<br/>
        <b>University of Tehran</b><br/>
        Faculty of Electrical and Computer Engineering<br/>
        Second Semester 1404-1405 (2025‑2026)<br/><br/>
        <b>Open Source</b><br/>
        This project is licensed under MIT. Source code available on GitHub.
        ]]>
    </string>
