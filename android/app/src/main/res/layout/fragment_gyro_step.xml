<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:gravity="center" android:orientation="vertical" android:padding="24dp"
    android:background="#0f1115">

    <TextView android:id="@+id/statusText"
        android:text="Place phone on flat surface and press Start"
        android:textColor="#e5e7eb" android:textSize="16sp" android:textAlignment="center"
        android:layout_marginBottom="16dp"/>

    <ProgressBar android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100"
        android:visibility="invisible"/>

    <Button android:id="@+id/startBtn" android:text="Start"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
</LinearLayout>