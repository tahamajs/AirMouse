<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC000000"
    android:padding="8dp">
    <TextView android:id="@+id/debug_gyro" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gyro: --" android:textColor="#FFFFFF" android:textSize="10sp"/>
    <TextView android:id="@+id/debug_accel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Accel: --" android:textColor="#FFFFFF" android:textSize="10sp"/>
    <TextView android:id="@+id/debug_orientation" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Orientation: --" android:textColor="#FFFFFF" android:textSize="10sp"/>
    <TextView android:id="@+id/debug_gesture" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gesture: --" android:textColor="#FFFFFF" android:textSize="10sp"/>
    <TextView android:id="@+id/debug_connection" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Connection: --" android:textColor="#FFFFFF" android:textSize="10sp"/>
    <TextView android:id="@+id/debug_fps" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FPS: --" android:textColor="#FFFFFF" android:textSize="10sp"/>
    <com.airmouse.ui.DebugOverlay.GraphCanvas
        android:id="@+id/debug_graph"
        android:layout_width="300dp"
        android:layout_height="100dp" />
</LinearLayout>