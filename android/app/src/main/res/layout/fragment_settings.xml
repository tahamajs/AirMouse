<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Click Speed Threshold -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/click_speed_threshold"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <SeekBar
            android:id="@+id/clickThresholdSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100" />

        <TextView
            android:id="@+id/clickThresholdValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- Double Click Interval -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/double_click_interval"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <SeekBar
            android:id="@+id/doubleClickSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="80" />

        <TextView
            android:id="@+id/doubleClickValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- Scroll Speed Threshold -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/scroll_sensitivity"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <SeekBar
            android:id="@+id/scrollThresholdSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="75" />

        <TextView
            android:id="@+id/scrollThresholdValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- Right Click Tilt Angle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/right_click_tilt"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <SeekBar
            android:id="@+id/tiltThresholdSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="90" />

        <TextView
            android:id="@+id/tiltThresholdValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- Haptic Feedback -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/haptic_feedback" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/hapticSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>