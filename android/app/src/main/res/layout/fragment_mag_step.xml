<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:gravity="center" android:orientation="vertical" android:padding="24dp"
    android:background="#0f1115">

    <TextView android:id="@+id/statusText"
        android:text="Move phone in figure‑8 pattern..."
        android:textColor="#e5e7eb" android:textSize="16sp" android:textAlignment="center"
        android:layout_marginBottom="16dp"/>

    <ProgressBar android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent" android:layout_height="wrap_content" android:max="200"/>
</LinearLayout>