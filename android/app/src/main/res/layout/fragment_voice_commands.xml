<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_mic"
        android:tint="@color/accent_blue" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voice Commands"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Say 'click', 'double click', 'right click', 'scroll up', 'scroll down'"
        android:textAlignment="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/voice_listen_btn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Start Listening"
        app:icon="@drawable/ic_mic"
        app:iconGravity="textStart"
        app:backgroundTint="@color/success_green"
        android:textColor="@android:color/white" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/voice_stop_btn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:text="Stop Listening"
        app:icon="@drawable/ic_stop"
        app:iconGravity="textStart"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:textColor="@color/error_red" />

    <TextView
        android:id="@+id/voice_result_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Ready"
        android:gravity="center"
        android:background="@drawable/bg_coach"
        android:padding="12dp" />

</LinearLayout>


