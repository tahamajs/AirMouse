<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:animateLayoutChanges="true">

        <!-- Header Greeting Area (Optional – you can add dynamic greeting later) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_title"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/connection_quality_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_signal_none"
                android:contentDescription="@string/connection_quality_icon_desc" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/home_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- ============================================================ -->
        <!-- MODE TOGGLE – Segmented button style (touchpad / motion)       -->
        <!-- ============================================================ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="32dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface_dark"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/modeToggle"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/motion_mode"
                    android:textColor="@android:color/white"
                    app:cornerRadius="28dp"
                    app:backgroundTint="@color/accent_blue"
                    android:layout_marginEnd="4dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/modeToggleTouchpad"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/touchpad_mode"
                    android:textColor="@color/text_secondary"
                    app:cornerRadius="28dp"
                    app:backgroundTint="@android:color/transparent"
                    android:stateListAnimator="@null"
                    android:elevation="0dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Motion Controls Container (shown by default, hidden in touchpad mode) -->
        <LinearLayout
            android:id="@+id/motionControlsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- 1. CONNECTION CARD – with live status and quick actions -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/connectionCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_dark"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/connect_to_pc"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/status_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/connection_unset"
                            android:textColor="@color/error_red"
                            android:textSize="13sp"
                            android:background="@drawable/status_badge"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <EditText
                            android:id="@+id/ip_edit_text"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:background="@drawable/input_background"
                            android:hint="@string/ip_hint"
                            android:inputType="phone"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:paddingHorizontal="16dp"
                            android:layout_marginEnd="8dp" />

                        <EditText
                            android:id="@+id/port_edit_text"
                            android:layout_width="90dp"
                            android:layout_height="56dp"
                            android:background="@drawable/input_background"
                            android:hint="@string/port_hint"
                            android:inputType="number"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:paddingHorizontal="12dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/connect_btn"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:text="@string/connect"
                            app:icon="@drawable/ic_connect"
                            app:iconGravity="textStart"
                            app:backgroundTint="@color/accent_blue"
                            android:textColor="@android:color/white"
                            android:layout_marginEnd="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/scan_qr_btn"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:text=""
                            app:icon="@drawable/ic_qr_scanner"
                            app:iconTint="@android:color/white"
                            app:backgroundTint="@color/surface_light"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/bt_mouse_btn"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="@string/use_bluetooth_mouse"
                            app:icon="@drawable/ic_bluetooth"
                            app:iconGravity="textStart"
                            app:backgroundTint="@color/accent_blue"
                            android:textColor="@android:color/white"
                            android:layout_marginBottom="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/calibrate_btn"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="@string/calibrate_sensors"
                        app:icon="@drawable/ic_calibrate"
                        app:iconGravity="textStart"
                        app:backgroundTint="@color/success_green"
                        android:textColor="@android:color/white" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. CALIBRATION STATUS CARD – Progress and attempts -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/calibrationCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_dark"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/calibration_title"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/calibration_progress_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/calibration_progress_default"
                            android:textColor="@color/accent_blue"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/calibration_progress_bar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="@color/accent_blue"
                        android:backgroundTint="@color/progress_bg"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/attempts_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/attempts_remaining_default"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. SENSOR DATA CARD – Live orientation and values -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/sensorDataCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_dark"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/motion_preview"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <FrameLayout
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/circle_bg">

                            <View
                                android:id="@+id/orientation_view"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:background="@drawable/ic_green_dot"
                                android:layout_gravity="center" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:id="@+id/gyro_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/yaw_default"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/accel_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/pitch_default"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4. GESTURE STATS CARD – quick summary -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/gestureStatsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_dark"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/gesture_summary"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2"
                        android:useDefaultMargins="true">

                        <TextView
                            android:id="@+id/click_count"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/clicks_default"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:drawableStart="@drawable/ic_click"
                            android:drawablePadding="8dp" />

                        <TextView
                            android:id="@+id/scroll_count"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/scrolls_default"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:drawableStart="@drawable/ic_scroll"
                            android:drawablePadding="8dp" />

                        <TextView
                            android:id="@+id/right_click_count"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/right_clicks_default"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:drawableStart="@drawable/ic_right_click"
                            android:drawablePadding="8dp" />

                        <TextView
                            android:id="@+id/double_click_count"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/double_clicks_default"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:drawableStart="@drawable/ic_double_click"
                            android:drawablePadding="8dp" />
                    </GridLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 5. CONTROLS CARD – Sensitivity, Start/Stop, Settings, Debug -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/controlsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_dark"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cursor_sensitivity_title"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sensitivity_slider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="100"
                        android:value="50"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/sensitivity_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sensitivity_default"
                        android:textColor="@color/accent_blue"
                        android:textSize="14sp"
                        android:layout_gravity="end"
                        android:layout_marginBottom="20dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/start_stop_btn"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:text="@string/start"
                            app:icon="@drawable/ic_play"
                            app:iconGravity="textStart"
                            app:backgroundTint="@color/success_green"
                            android:textColor="@android:color/white"
                            android:layout_marginEnd="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/settings_btn"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:text="@string/settings_button_label"
                            app:icon="@drawable/ic_settings"
                            app:iconGravity="textStart"
                            app:backgroundTint="@color/surface_light"
                            android:textColor="@android:color/white"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/debug_toggle_btn"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:text="@string/debug_button_label"
                            app:icon="@drawable/ic_debug"
                            app:iconGravity="textStart"
                            app:backgroundTint="@color/surface_light"
                            android:textColor="@android:color/white"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Touchpad Container (shown only in touchpad mode) -->
        <FrameLayout
            android:id="@+id/touchpadContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone" />

        <!-- Live Log Card (always visible, but can be hidden if needed) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_dark"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/recent_activity"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/clear_logs_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="@string/clear_logs"
                        app:icon="@drawable/ic_clear"
                        app:iconGravity="textStart"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@drawable/log_background">

                    <TextView
                        android:id="@+id/live_log_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/live_log_empty"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:padding="8dp" />
                </ScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Floating Action Button for quick calibration access -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/calibrate_fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:layout_margin="16dp"
            android:src="@drawable/ic_calibrate"
            app:backgroundTint="@color/accent_blue"
            app:tint="@android:color/white" />

    </LinearLayout>
</ScrollView>
