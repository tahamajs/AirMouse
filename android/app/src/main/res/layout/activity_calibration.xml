<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0f1115">

    <!-- Compose header (migrated) -->
    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/headerCompose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Backward-compatible hidden header elements (kept for activity state) -->
    <TextView
        android:id="@+id/statusHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:text="@string/calibration_welcome" />

    <ProgressBar
        android:id="@+id/overallProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:visibility="gone"
        android:max="100"
        android:progress="0" />

    <!-- Hidden legacy controls for gradual migration (kept to avoid changing activity logic) -->
    <TextView
        android:id="@+id/timerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:text="00:00" />

    <Button
        android:id="@+id/backBtn"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />
    <Button
        android:id="@+id/nextBtn"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />
    <Button
        android:id="@+id/stopBtn"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- Task checklist (horizontal) -->
    <LinearLayout
        android:id="@+id/taskChecklist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp"
        android:background="#171b22">

        <TextView
            android:id="@+id/gyroCheck"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⬜ Gyroscope"
            android:textColor="#96a0ae"
            android:textSize="14sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/accelCheck"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⬜ Accelerometer"
            android:textColor="#96a0ae"
            android:textSize="14sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/magCheck"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⬜ Magnetometer"
            android:textColor="#96a0ae"
            android:textSize="14sp"
            android:gravity="center" />
    </LinearLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#171b22"
        app:tabTextColor="#96a0ae"
        app:tabSelectedTextColor="#ffffff"
        app:tabIndicatorColor="#007acc"
        app:tabIndicatorHeight="3dp"
        app:tabRippleColor="#1d2430"
        android:paddingVertical="8dp">
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gyroscope" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Accelerometer" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Magnetometer" />
    </com.google.android.material.tabs.TabLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
    <!-- Compose bottom controls (migrated) -->
    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/bottomCompose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>