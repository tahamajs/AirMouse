<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Click Threshold"
        android:textAppearance="?attr/textAppearanceTitleSmall" />

    <SeekBar
        android:id="@+id/clickThresholdSeek"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100" />

    <TextView
        android:id="@+id/clickThresholdValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Double Click Interval"
        android:textAppearance="?attr/textAppearanceTitleSmall" />

    <SeekBar
        android:id="@+id/doubleClickSeek"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="80" />

    <TextView
        android:id="@+id/doubleClickValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scroll Threshold"
        android:textAppearance="?attr/textAppearanceTitleSmall" />

    <SeekBar
        android:id="@+id/scrollThresholdSeek"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="75" />

    <TextView
        android:id="@+id/scrollThresholdValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Right‑Click Tilt Angle"
        android:textAppearance="?attr/textAppearanceTitleSmall" />

    <SeekBar
        android:id="@+id/tiltThresholdSeek"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="90" />

    <TextView
        android:id="@+id/tiltThresholdValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Haptic Feedback"
            android:textAppearance="?attr/textAppearanceBody1" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/hapticSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>
</LinearLayout>