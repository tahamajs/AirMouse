<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Main Recording Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_dark"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_gesture"
                        android:tint="@color/accent_blue" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Gesture Recorder"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Record custom gestures to train your own AI model"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginBottom="20dp" />

                <!-- Gesture Name Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Gesture name (e.g., CircleCW, LeftSwipe, ThumbsUp)"
                    app:endIconMode="clear_text"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/gesture_name_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Recording Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/start_record_btn"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="Start Recording"
                        app:icon="@drawable/ic_record"
                        app:iconGravity="textStart"
                        app:backgroundTint="@color/success_green"
                        android:textColor="@android:color/white"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/stop_record_btn"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="Stop Recording"
                        app:icon="@drawable/ic_stop"
                        app:iconGravity="textStart"
                        app:backgroundTint="@color/error_red"
                        android:textColor="@android:color/white"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <!-- Recording Status -->
                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ready"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textAlignment="center"
                    android:background="@drawable/bg_coach"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp" />

                <!-- Dataset Info -->
                <TextView
                    android:id="@+id/dataset_info_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No dataset yet"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textAlignment="center"
                    android:background="@drawable/bg_instruction"
                    android:padding="8dp"
                    android:layout_marginBottom="16dp" />

                <!-- Export Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/export_dataset_btn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Export Dataset (CSV)"
                    app:icon="@drawable/ic_export"
                    app:iconGravity="textStart"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:textColor="@color/text_primary" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Training Instructions Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_dark"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📚 How to Train Your Model"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1️⃣ Name your gesture (e.g., CircleCW)\n\n2️⃣ Tap 'Start Recording' and perform the gesture 5‑10 times\n\n3️⃣ Tap 'Stop Recording' when done\n\n4️⃣ Repeat for other gestures (at least 2 required)\n\n5️⃣ Tap 'Export Dataset' to save CSV file\n\n6️⃣ Copy CSV to your PC\n\n7️⃣ Run the Python training script\n\n8️⃣ Copy the resulting .tflite and .json files back to assets/\n\n9️⃣ Restart the app – your gesture is now recognized!"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingExtra="6dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tips Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_dark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 Tips for Best Results"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Hold the phone with a consistent grip each time.\n\n• Perform the gesture at a natural, steady speed.\n\n• Record at least 5‑10 repetitions per gesture.\n\n• Keep the phone in the same orientation (screen facing you).\n\n• Avoid background magnetic fields (keep away from metal).\n\n• For two‑handed gestures, hold the phone with one hand.\n\n• After training, test the gesture in the main app."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingExtra="6dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>