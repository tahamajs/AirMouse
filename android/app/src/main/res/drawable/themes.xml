<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.AirMouse" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/background_dark</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.AirMouse.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/deep_orange_700</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_air_mouse</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="postSplashScreenTheme">@style/Theme.AirMouse</item>
    </style>
</resources>