<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================= -->
    <!-- SPLASH THEME (Android 12+)    -->
    <!-- ============================= -->
    <style name="Theme.AirMouse.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/deep_orange_700</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_calibrate</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="postSplashScreenTheme">@style/Theme.AirMouse</item>
    </style>

    <!-- ============================= -->
    <!-- BASE LIGHT THEME              -->
    <!-- ============================= -->
    <style name="Theme.AirMouse" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Status & navigation bars -->
        <item name="android:statusBarColor">@color/deep_orange_700</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/background_primary</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Brand colors -->
        <item name="colorPrimary">@color/deep_orange_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/deep_orange_100</item>
        <item name="colorOnPrimaryContainer">@color/deep_orange_900</item>

        <item name="colorSecondary">@color/amber_500</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">@color/amber_200</item>
        <item name="colorOnSecondaryContainer">@color/amber_900</item>

        <item name="colorTertiary">@color/success</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorTertiaryContainer">@color/success</item>
        <item name="colorOnTertiaryContainer">@color/white</item>

        <!-- Surface & background -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:windowBackground">@color/background_primary</item>
        <item name="colorBackground">@color/background_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>

        <!-- Typography -->
        <item name="textAppearanceHeadline1">@style/TextAppearance.AirMouse.Headline1</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.AirMouse.Headline2</item>
        <item name="textAppearanceHeadline3">@style/TextAppearance.AirMouse.Headline3</item>
        <item name="textAppearanceHeadline4">@style/TextAppearance.AirMouse.Headline4</item>
        <item name="textAppearanceHeadline5">@style/TextAppearance.AirMouse.Headline5</item>
        <item name="textAppearanceHeadline6">@style/TextAppearance.AirMouse.Headline6</item>
        <item name="textAppearanceSubtitle1">@style/TextAppearance.AirMouse.Subtitle1</item>
        <item name="textAppearanceSubtitle2">@style/TextAppearance.AirMouse.Subtitle2</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.AirMouse.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.AirMouse.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.AirMouse.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.AirMouse.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.AirMouse.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.AirMouse.LabelSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.AirMouse.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.AirMouse.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.AirMouse.TitleSmall</item>

        <!-- Shape (rounded corners) -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.AirMouse.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.AirMouse.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.AirMouse.Large</item>

        <!-- Dialogs -->
        <item name="android:dialogTheme">@style/Theme.AirMouse.Dialog</item>

        <!-- Widget styles -->
        <item name="materialButtonStyle">@style/Widget.AirMouse.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.AirMouse.Button.Outlined</item>
        <item name="materialButtonTonalStyle">@style/Widget.AirMouse.Button.Tonal</item>
        <item name="materialButtonTextStyle">@style/Widget.AirMouse.Button.Text</item>
        <item name="materialCardViewStyle">@style/Widget.AirMouse.CardView</item>
        <item name="bottomNavigationStyle">@style/Widget.AirMouse.BottomNavigation</item>
        <item name="floatingActionButtonStyle">@style/Widget.AirMouse.FAB</item>
        <item name="textInputStyle">@style/Widget.AirMouse.TextInputLayout</item>
        <item name="actionBarTheme">@style/Theme.AirMouse.ActionBar</item>
        <item name="toolbarStyle">@style/Widget.AirMouse.Toolbar</item>
        <item name="switchStyle">@style/Widget.AirMouse.Switch</item>
        <item name="checkboxStyle">@style/Widget.AirMouse.CheckBox</item>
        <item name="radioButtonStyle">@style/Widget.AirMouse.RadioButton</item>
        <item name="seekBarStyle">@style/Widget.AirMouse.SeekBar</item>

        <!-- Navigation drawer (optional) -->
        <item name="navigationViewStyle">@style/Widget.AirMouse.NavigationView</item>
    </style>

    <!-- ============================= -->
    <!-- ADDITIONAL THEMES             -->
    <!-- ============================= -->

    <!-- Pure Black theme (AMOLED) -->
    <style name="Theme.AirMouse.PureBlack" parent="Theme.AirMouse">
        <item name="android:windowBackground">@color/black_pure</item>
        <item name="colorSurface">@color/black_pure</item>
        <item name="colorBackground">@color/black_pure</item>
        <item name="colorSurfaceVariant">@color/black_pure</item>
    </style>

    <!-- High Contrast theme (accessibility) -->
    <style name="Theme.AirMouse.HighContrast" parent="Theme.AirMouse">
        <item name="colorPrimary">@color/deep_orange_800</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/amber_700</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black_pure</item>
    </style>

    <!-- ============================= -->
    <!-- DIALOG THEME                  -->
    <!-- ============================= -->
    <style name="Theme.AirMouse.Dialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="colorPrimary">@color/deep_orange_500</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/Widget.Air.Button.Positive</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/Widget.Air.Button.Negative</item>
    </style>

    <!-- ActionBar theme (if used) -->
    <style name="Theme.AirMouse.ActionBar" parent="ThemeOverlay.Material3.ActionBar">
        <item name="android:background">@color/deep_orange_500</item>
        <item name="android:titleTextStyle">@style/TextAppearance.AirMouse.TitleLarge</item>
    </style>

    <!-- ============================= -->
    <!-- TYPOGRAPHY STYLES (extended)  -->
    <!-- ============================= -->
    <style name="TextAppearance.AirMouse.Headline1" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">34sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextAppearance.AirMouse.Headline2" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">28sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextAppearance.AirMouse.Headline3" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">22sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="TextAppearance.AirMouse.Headline4" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">20sp</item>
    </style>
    <style name="TextAppearance.AirMouse.Headline5" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">18sp</item>
    </style>
    <style name="TextAppearance.AirMouse.Headline6" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">16sp</item>
    </style>
    <style name="TextAppearance.AirMouse.Subtitle1" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">16sp</item>
    </style>
    <style name="TextAppearance.AirMouse.Subtitle2" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">14sp</item>
    </style>
    <style name="TextAppearance.AirMouse.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">20sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextAppearance.AirMouse.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextAppearance.AirMouse.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">16sp</item>
    </style>
    <style name="TextAppearance.AirMouse.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="TextAppearance.AirMouse.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="TextAppearance.AirMouse.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="TextAppearance.AirMouse.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextAppearance.AirMouse.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
    </style>
    <style name="TextAppearance.AirMouse.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
    </style>

    <!-- ============================= -->
    <!-- SHAPE APPEARANCES             -->
    <!-- ============================= -->
    <style name="ShapeAppearance.AirMouse.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    <style name="ShapeAppearance.AirMouse.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    <style name="ShapeAppearance.AirMouse.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <!-- ============================= -->
    <!-- BUTTON STYLES                 -->
    <!-- ============================= -->
    <style name="Widget.AirMouse.Button" parent="Widget.Material3.Button">
        <item name="android:textAppearance">@style/TextAppearance.AirMouse.LabelLarge</item>
        <item name="shapeAppearance">@style/ShapeAppearance.AirMouse.Medium</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:paddingHorizontal">24dp</item>
        <item name="android:minHeight">48dp</item>
    </style>
    <style name="Widget.AirMouse.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAppearance">@style/TextAppearance.AirMouse.LabelLarge</item>
        <item name="shapeAppearance">@style/ShapeAppearance.AirMouse.Medium</item>
    </style>
    <style name="Widget.AirMouse.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textAppearance">@style/TextAppearance.AirMouse.LabelLarge</item>
        <item name="shapeAppearance">@style/ShapeAppearance.AirMouse.Medium</item>
    </style>
    <style name="Widget.AirMouse.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAppearance">@style/TextAppearance.AirMouse.LabelLarge</item>
    </style>

    <!-- Dialog buttons -->
    <style name="Widget.Air.Button.Positive" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/deep_orange_500</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="Widget.Air.Button.Negative" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/grey_600</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- ============================= -->
    <!-- CARD VIEW STYLE               -->
    <!-- ============================= -->
    <style name="Widget.AirMouse.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="shapeAppearance">@style/ShapeAppearance.AirMouse.Large</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardPreventCornerOverlap">true</item>
    </style>

    <!-- ============================= -->
    <!-- BOTTOM NAVIGATION STYLE       -->
    <!-- ============================= -->
    <style name="Widget.AirMouse.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/surface</item>
        <item name="android:elevation">8dp</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.AirMouse.LabelLarge</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.AirMouse.BodySmall</item>
        <item name="itemIconSize">24dp</item>
        <item name="itemRippleColor">?attr/colorPrimary</item>
    </style>

    <!-- ============================= -->
    <!-- FAB STYLE                     -->
    <!-- ============================= -->
    <style name="Widget.AirMouse.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="android:tint">@color/white</item>
        <item name="elevation">6dp</item>
        <item name="rippleColor">@color/white</item>
        <item name="fabSize">normal</item>
    </style>

    <!-- ============================= -->
    <!-- TEXT INPUT LAYOUT STYLE       -->
    <!-- ============================= -->
    <style name="Widget.AirMouse.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="shapeAppearance">@style/ShapeAppearance.AirMouse.Medium</item>
        <item name="boxStrokeColor">@color/deep_orange_500</item>
        <item name="boxStrokeErrorColor">@color/error</item>
        <item name="hintTextAppearance">@style/TextAppearance.AirMouse.BodySmall</item>
    </style>

    <!-- ============================= -->
    <!-- TOOLBAR STYLE                 -->
    <!-- ============================= -->
    <style name="Widget.AirMouse.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/deep_orange_500</item>
        <item name="android:titleTextAppearance">@style/TextAppearance.AirMouse.TitleLarge</item>
        <item name="titleTextColor">@color/white</item>
    </style>

    <!-- ============================= -->
    <!-- SWITCH, CHECKBOX, RADIO       -->
    <!-- ============================= -->
    <style name="Widget.AirMouse.Switch" parent="Widget.Material3.CompoundButton.Switch">
        <item name="thumbTint">?attr/colorPrimary</item>
        <item name="trackTint">?attr/colorPrimaryContainer</item>
    </style>
    <style name="Widget.AirMouse.CheckBox" parent="Widget.Material3.CompoundButton.CheckBox">
        <item name="buttonTint">?attr/colorPrimary</item>
    </style>
    <style name="Widget.AirMouse.RadioButton" parent="Widget.Material3.CompoundButton.RadioButton">
        <item name="buttonTint">?attr/colorPrimary</item>
    </style>

    <!-- ============================= -->
    <!-- SEEKBAR STYLE                 -->
    <!-- ============================= -->
    <style name="Widget.AirMouse.SeekBar" parent="Widget.Material3.SeekBar">
        <item name="progressTint">?attr/colorPrimary</item>
        <item name="thumbTint">?attr/colorPrimary</item>
    </style>

    <!-- ============================= -->
    <!-- NAVIGATION VIEW (drawer)      -->
    <!-- ============================= -->
    <style name="Widget.AirMouse.NavigationView" parent="Widget.Material3.NavigationView">
        <item name="android:background">@color/surface</item>
        <item name="itemTextColor">@color/text_primary</item>
        <item name="itemIconTint">@color/text_primary</item>
        <item name="itemBackground">?attr/selectableItemBackground</item>
    </style>
    <!-- Pure Black (AMOLED) theme – override background and surface -->
    <style name="Theme.AirMouse.PureBlack" parent="Theme.AirMouse">
        <item name="android:windowBackground">@color/black_pure</item>
        <item name="colorSurface">@color/black_pure</item>
        <item name="colorBackground">@color/black_pure</item>
        <item name="colorSurfaceVariant">@color/black_pure</item>
    </style>

    <!-- High Contrast theme -->
    <style name="Theme.AirMouse.HighContrast" parent="Theme.AirMouse">
        <item name="colorPrimary">@color/deep_orange_800</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/amber_700</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black_pure</item>
    </style>
</resources>

