<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ==================== SPLASH SCREEN ==================== -->
    <style name="Theme.AirMouse.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="windowSplashScreenAnimationDuration">800</item>
        <item name="postSplashScreenTheme">@style/Theme.AirMouse</item>
    </style>

    <!-- ==================== BASE THEMES ==================== -->

    <!-- Base App Theme (AppCompat) -->
    <style name="Theme.AirMouse" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/background_dark</item>

        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryVariant">@color/primary</item>
        <item name="colorSecondary">@color/secondary_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surfaceModern</item>
        <item name="colorOnSurface">@color/onSurfaceModern</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>
    </style>

    <!-- Light Theme -->
    <style name="Theme.AirMouse.Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor">@color/deep_orange_700</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/background_primary</item>

        <item name="colorPrimary">@color/deep_orange_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryVariant">@color/deep_orange_700</item>
        <item name="colorSecondary">@color/amber_500</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/background_primary</item>
    </style>

    <!-- Dark Theme -->
    <style name="Theme.AirMouse.Dark" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/deep_orange_800</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/background_primary</item>

        <item name="colorPrimary">@color/deep_orange_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryVariant">@color/deep_orange_800</item>
        <item name="colorSecondary">@color/amber_500</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/background_primary</item>
    </style>

    <!-- Pure Black (AMOLED) Theme -->
    <style name="Theme.AirMouse.PureBlack" parent="Theme.AirMouse.Dark">
        <item name="android:statusBarColor">@color/black_pure</item>
        <item name="android:windowBackground">@color/black_pure</item>
        <item name="colorSurface">@color/black_pure</item>
        <item name="colorPrimary">@color/deep_orange_400</item>
    </style>

    <!-- High Contrast Theme -->
    <style name="Theme.AirMouse.HighContrast" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/deep_orange_800</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/amber_700</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black_pure</item>
        <item name="android:statusBarColor">@color/black_pure</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- ==================== DIALOG & OVERLAY THEMES ==================== -->

    <!-- Dialog Theme -->
    <style name="Theme.AirMouse.Dialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="colorPrimary">@color/deep_orange_500</item>
    </style>

    <!-- Transparent Theme for QR Scanner -->
    <style name="Theme.AirMouse.Transparent" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- ==================== SHAPE APPEARANCES ==================== -->

    <style name="ShapeAppearanceOverlay.App.CornerSize50Percent" parent="">
        <item name="cornerSize">50%</item>
    </style>
</resources>
