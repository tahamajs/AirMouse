<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- Main Destinations -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.airmouse.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/statisticsFragment"
        android:name="com.airmouse.StatisticsFragment"
        android:label="Statistics"
        tools:layout="@layout/fragment_statistics" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.airmouse.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/helpFragment"
        android:name="com.airmouse.HelpFragment"
        android:label="Help"
        tools:layout="@layout/fragment_help" />

    <fragment
        android:id="@+id/aboutFragment"
        android:name="com.airmouse.AboutFragment"
        android:label="About"
        tools:layout="@layout/fragment_about" />

    <!-- Advanced Features -->
    <fragment
        android:id="@+id/networkDiscoveryFragment"
        android:name="com.airmouse.NetworkDiscoveryFragment"
        android:label="Network Discovery"
        tools:layout="@layout/fragment_network_discovery" />

    <fragment
        android:id="@+id/profilesFragment"
        android:name="com.airmouse.ProfilesFragment"
        android:label="Profiles"
        tools:layout="@layout/fragment_profiles" />

    <fragment
        android:id="@+id/gestureStudioFragment"
        android:name="com.airmouse.GestureStudioFragment"
        android:label="Gesture Studio"
        tools:layout="@layout/fragment_gesture_studio" />

    <fragment
        android:id="@+id/edgeGesturesFragment"
        android:name="com.airmouse.EdgeGesturesFragment"
        android:label="Edge Gestures"
        tools:layout="@layout/fragment_edge_gestures" />

    <fragment
        android:id="@+id/voiceCommandsFragment"
        android:name="com.airmouse.VoiceCommandsFragment"
        android:label="Voice Commands"
        tools:layout="@layout/fragment_voice_commands" />

    <fragment
        android:id="@+id/themesFragment"
        android:name="com.airmouse.ThemesFragment"
        android:label="Themes"
        tools:layout="@layout/fragment_themes" />

    <fragment
        android:id="@+id/serverLogFragment"
        android:name="com.airmouse.ServerLogFragment"
        android:label="Server Logs"
        tools:layout="@layout/fragment_server_log" />

    <fragment
        android:id="@+id/batteryGraphFragment"
        android:name="com.airmouse.BatteryGraphFragment"
        android:label="Battery Monitor"
        tools:layout="@layout/fragment_battery" />

    <fragment
        android:id="@+id/accessibilityFragment"
        android:name="com.airmouse.AccessibilityFragment"
        android:label="Accessibility"
        tools:layout="@layout/fragment_accessibility" />

    <fragment
        android:id="@+id/proximitySettingsFragment"
        android:name="com.airmouse.ProximitySettingsFragment"
        android:label="Proximity Lock"
        tools:layout="@layout/fragment_proximity" />

    <!-- Onboarding Flow -->
    <activity
        android:id="@+id/onboardingActivity"
        android:name="com.airmouse.ui.onboarding.OnboardingActivity"
        android:label="Onboarding" />

    <!-- Actions -->
    <action
        android:id="@+id/action_global_calibration"
        app:destination="@id/homeFragment" />

</navigation>
